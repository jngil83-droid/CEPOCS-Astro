const fotoTitulos = ['Entrega de agradecimiento a la AECID por el apoyo a Frutada', 'Denuncia de CEPOCS y FEMUCOS al feminicidio en RD', 'Apoyo a organizaciones a cacaoteras', 'Mujeres preparando frutas para ser procesadas', 'Supervision de Coordinador de Prodiversa al equipamiento de procesadora de Café', 'Muestra de jugos elaborados por Frutada (proyecto de AECID)', 'Infraestructuras creadas en proyecto de AECID para procesadora de jugos "Frutada"', 'Firma de acuerdo entre INTABACO, FEMUCOS y CEPOCS', 'Inicio de construcción de Procesadora de Café en la Cayota', 'Camioneta con guanábana​s para su procesamiento', 'Muestra de jugos elaborados por Frutada (proyecto de AECID)', 'Participación en manifestación contra feminicidios', 'Recopilación de información en proceso de identificación', 'Beneficiaria de proyecto de cacao (AECID)', 'Beneficiarias de proyecto de cacao (AECID)', 'Beneficiario de proyecto de cacao (AECID)', 'Coordinador de Prodiversa junto a beneficiarias en la procesadora de Café', 'Reunión de FEMUCOS junto a mujeres y entidades socias', 'Visita de la AECID a FRUTADA', 'Mujer añadiendo etiquetas a jugos para su venta', 'Visita de la AECID a campos de café', 'Visita de la AECID a inicio de construcción de procesadora de café', 'Vicepresidenta de CEPOCS en un discurso', 'Muestra de Café Paradero', 'Beneficiaria en su conuco', 'Mujeres descargando insumos para sus conucos', 'Reunión de proyecto en Montecristi (Manos Unidas)'];
const fotos = fotoUrls.map((url, index) => ({
  url,
  titulo: fotoTitulos[index] ?? 'Memorias de CEPOCS',
  categoria: index < 8 ? 'Comunidad y territorio' : 'Archivo CEPOCS'
}));

const videos = [
  { url: "https://www.youtube.com/embed/4Ph5ZhSizh8", titulo: "Contra los feminicidios" },
  { url: "https://www.youtube.com/embed/kCRBCTF6XY4", titulo: "Prueba Café Paradero" },
  { url: "https://www.youtube.com/embed/UKU0S8u2ruE", titulo: "Más independiente gracias a CEPOCS" },
  { url: "https://www.youtube.com/embed/K8IXvDBhaPI", titulo: "Mujeres de la costa de Montecristi y ganadería caprina" },
  { url: "https://www.youtube.com/embed/lKwXbkYBCCc", titulo: "Cierre del proyecto de fondos Canadá" },
  { url: "https://www.youtube.com/embed/zExraq8ixHY", titulo: "Proyecto CEPOCS - 15 dic 2025" },
  { url: "https://www.youtube.com/embed/rc-8jl9uvOI", titulo: "Proyecto fondo Canadá - Cordillera" },
  { url: "https://www.youtube.com/embed/C9UHnD88mFw", titulo: "Oficina provincial Valverde" },
  { url: "https://www.youtube.com/embed/CZwkFqQhOZU", titulo: "Nueva Oficina en Navarrete" }
];
---

<Layout title="Multimedia | CEPOCS">
<section class="multimedia-hero">
  <div class="container">
    <h1 class="section-title">NUESTRA HISTORIA EN IMÁGENES</h1>
    <div class="thanks-message texto-destacado">
      Fotografías, videos y testimonios que reflejan el trabajo realizado por CEPOCS junto a las comunidades rurales de la Cordillera Septentrional.
    </div>
    <nav class="media-shortcuts" aria-label="Explorar multimedia">
      <a href="#fotos">Explorar fotografías <span aria-hidden="true">↓</span></a>
      <a href="#videos">Ver videos <span aria-hidden="true">↓</span></a>
    </nav>
  </div>
</section>

<main class="multimedia-container">

  <section class="section-block">
    <h2 id="fotos">Fotografías</h2>

  <div id="galleryGrid" class="gallery-grid">
  {
    fotos.map((foto, index) => (
      <figure
        class={`gallery-card ${index % 5 === 0 ? 'gallery-card-featured gallery-card-featured-right' : ''} ${index >= 10 ? 'hidden-photo' : ''}`}
        data-index={index}
        style={index % 5 === 0 ? `--featured-row: ${Math.floor(index / 5) * 2 + 1};` : undefined}
      >
        <button class="gallery-thumb" aria-label={`Abrir: ${foto.titulo}`}>
          <img
            src={foto.url}
            alt={foto.titulo}
            loading="lazy"
            decoding="async"
          />
          <span class="gallery-overlay"><span>{foto.categoria}</span><strong>{foto.titulo}</strong></span>
        </button>
        <figcaption class="sr-only">{foto.titulo}, {foto.categoria}</figcaption>
      </figure>
    ))
  }
  </div>

  <button id="togglePhotos" class="load-more-btn" type="button" aria-expanded="false" aria-controls="galleryGrid">
    Ver más fotografías
  </button>

  <!-- Lightbox modal -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="lbCaption">
    <div class="lightbox-inner">
      <button id="lbClose" class="lb-close" aria-label="Cerrar">✕</button>
      <button id="lbPrev" class="lb-nav lb-prev" aria-label="Imagen anterior">◀</button>
      <div class="lb-media">
        <img id="lbImage" src="" alt="" />
        <p id="lbCaption" class="lb-caption"></p>
        <p id="lbCounter" class="lb-counter" aria-live="polite"></p>
      </div>
      <button id="lbNext" class="lb-nav lb-next" aria-label="Siguiente imagen">▶</button>
    </div>
  </div>

  </section>

  <section class="section-block">
    <h2 id="videos">Videos</h2>

    <div id="videoGrid" class="video-grid">
{
  videos.map((video, index) => (
    <article
      class={`video-card ${index >= 6 ? 'hidden-video' : ''}`}
    >
      <button class="video-preview" type="button" data-video-url={video.url} aria-label={`Reproducir: ${video.titulo}`}>
        <img src={`https://i.ytimg.com/vi/${video.url.split('/').pop()}/hqdefault.jpg`} alt="" loading="lazy" decoding="async" />
        <span class="play-icon" aria-hidden="true">▶</span>
        <span class="play-label">Reproducir</span>
      </button>

      <h3>{video.titulo}</h3>
    </article>
  ))
}
</div>

<button id="toggleVideos" class="load-more-btn" type="button" aria-expanded="false" aria-controls="videoGrid">
  Ver más vídeos
</button>
  </section>

  <section class="multimedia-cta" aria-labelledby="multimedia-cta-title">
    <p>El trabajo continúa junto a las comunidades.</p>
    <h2 id="multimedia-cta-title">Conoce nuestros proyectos</h2>
    <div class="multimedia-cta-actions">
      <a href="/proyectos" class="btn btn-primary">Ver proyectos</a>
    </div>
  </section>

</main>
<script is:inline>
// Toggle photos/videos
const photoBtn = document.getElementById('togglePhotos');
const galleryGrid = document.getElementById('galleryGrid');
let photosOpen = false;
photoBtn?.addEventListener('click', () => {
  document.querySelectorAll('.hidden-photo').forEach(el => el.classList.toggle('is-visible', !photosOpen));
  photosOpen = !photosOpen;
  photoBtn.textContent = photosOpen ? 'Ver menos fotografías' : 'Ver más fotografías';
  photoBtn.setAttribute('aria-expanded', String(photosOpen));
});

const videoBtn = document.getElementById('toggleVideos');
let videosOpen = false;
videoBtn?.addEventListener('click', () => {
  document.querySelectorAll('.hidden-video').forEach(el => el.classList.toggle('is-visible', !videosOpen));
  videosOpen = !videosOpen;
  videoBtn.textContent = videosOpen ? 'Ver menos vídeos' : 'Ver más vídeos';
  videoBtn.setAttribute('aria-expanded', String(videosOpen));
});

// YouTube only loads after the visitor chooses a video.
document.querySelectorAll('.video-preview').forEach((preview) => {
  preview.addEventListener('click', () => {
    const iframe = document.createElement('iframe');
    iframe.className = 'video-frame';
    iframe.style.cssText = 'display:block;width:100%;height:230px;border:0;';
    iframe.src = `${preview.dataset.videoUrl}?autoplay=1&rel=0`;
    iframe.title = preview.closest('.video-card').querySelector('h3').textContent;
    iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
    iframe.allowFullscreen = true;
    preview.replaceWith(iframe);
  });
});

// Lightbox
const thumbs = Array.from(document.querySelectorAll('.gallery-thumb'));
const lightbox = document.getElementById('lightbox');
const lbImage = document.getElementById('lbImage');
const lbCaption = document.getElementById('lbCaption');
const lbCounter = document.getElementById('lbCounter');
const lbClose = document.getElementById('lbClose');
const lbPrev = document.getElementById('lbPrev');
const lbNext = document.getElementById('lbNext');
let currentIndex = 0;
let lastFocusedElement;

function openLightbox(index){
  const wasOpen = lightbox.classList.contains('open');
  const url = thumbs[index].querySelector('img').src;
  const alt = thumbs[index].querySelector('img').alt || '';
  lbImage.src = url;
  lbImage.alt = alt;
  lbCaption.textContent = alt || `Fotografía ${index+1}`;
  lbCounter.textContent = `Foto ${index + 1} de ${thumbs.length}`;
  lightbox.setAttribute('aria-hidden', 'false');
  lightbox.classList.add('open');
  currentIndex = index;
  if (!wasOpen) lastFocusedElement = document.activeElement;
  document.body.classList.add('lightbox-active');
  lbClose.focus();
}

function closeLightbox(){
  lightbox.setAttribute('aria-hidden', 'true');
  lightbox.classList.remove('open');
  lbImage.src = '';
  document.body.classList.remove('lightbox-active');
  lastFocusedElement?.focus();
}

function showNext(){
  currentIndex = (currentIndex + 1) % thumbs.length;
  openLightbox(currentIndex);
}

function showPrev(){
  currentIndex = (currentIndex - 1 + thumbs.length) % thumbs.length;
  openLightbox(currentIndex);
}

thumbs.forEach((btn, i) => btn.addEventListener('click', (e)=>{ e.preventDefault(); openLightbox(i); }));
lbClose?.addEventListener('click', closeLightbox);
lbNext?.addEventListener('click', (e)=>{ e.stopPropagation(); showNext(); });
lbPrev?.addEventListener('click', (e)=>{ e.stopPropagation(); showPrev(); });

lightbox?.addEventListener('click', (e)=>{ if(e.target === lightbox) closeLightbox(); });
document.addEventListener('keydown', (e)=>{
  if(!lightbox.classList.contains('open')) return;
  if(e.key === 'Escape') closeLightbox();
  if(e.key === 'ArrowRight') showNext();
  if(e.key === 'ArrowLeft') showPrev();
  if(e.key === 'Tab') {
    const controls = [lbClose, lbPrev, lbNext];
    const first = controls[0];
    const last = controls[controls.length - 1];
    if(e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
    if(!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
  }
});

</script>
</Layout>

<style>
.multimedia-container{
  max-width:1200px;
  margin:auto;
  padding:20px 20px 10px;
}

.multimedia-cta{margin:70px 0 30px;padding:48px 24px;text-align:center;border-radius:20px;background:var(--verde-soft);border:1px solid #e2ece1}
.multimedia-cta p{margin:0 0 4px;color:var(--gris);font-weight:600}
.multimedia-cta h2{margin:0 0 20px;color:var(--verde);font-size:clamp(1.55rem,3vw,2.15rem)}
.multimedia-cta-actions{display:flex;justify-content:center}

.multimedia-hero{
  padding:80px 0 40px;
  text-align:center;
  background:var(--verde-soft);
}

.multimedia-hero .section-title{
  font-weight:800;
  margin-bottom:1rem;
}

.media-shortcuts{display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
.media-shortcuts a{display:inline-flex;gap:8px;align-items:center;padding:10px 18px;border:1px solid rgba(15,76,58,.22);border-radius:999px;color:var(--verde);font-weight:700;text-decoration:none;background:#fff;transition:.2s}
.media-shortcuts a:hover{background:var(--verde);border-color:var(--verde);color:#fff;transform:translateY(-2px)}

.section-block{
  margin-top:70px;
}

.section-block h2{
  color:var(--naranja);
  margin-bottom:30px;
  padding-bottom:10px;
  border-bottom:2px solid #eee;
  font-size:1.9rem;
}

.gallery-grid{
  display:grid;
  grid-template-columns:repeat(4, minmax(0,1fr));
  grid-auto-rows:190px;
  gap:16px;
}

.gallery-card{
  position:relative;
  overflow:hidden;
  border-radius:16px;
  box-shadow:0 8px 24px rgba(0,0,0,.08);
  background:#fff;
}

.gallery-card-featured{grid-column:span 2;grid-row:var(--featured-row) / span 2}
.gallery-card-featured-right{grid-column:3 / span 2}

.gallery-card img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
  transition:.45s;
}

.gallery-card:hover img{
  transform:scale(1.08);
}

/* Lightbox styles */
.gallery-thumb{position:relative;border:0;background:transparent;padding:0;display:block;width:100%;height:100%;text-align:left;cursor:zoom-in;overflow:hidden}
.gallery-overlay{position:absolute;inset:auto 0 0;padding:34px 18px 16px;color:#fff;background:linear-gradient(transparent,rgba(0,0,0,.76));display:flex;flex-direction:column;opacity:0;transition:.25s}
.gallery-overlay span{font-size:.72rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#f8d4a7}.gallery-overlay strong{font-size:1rem;line-height:1.25}
.gallery-thumb:hover .gallery-overlay,.gallery-thumb:focus-visible .gallery-overlay{opacity:1}
.hidden-photo.is-visible,.hidden-video.is-visible{display:block}
.lightbox{position:fixed;inset:0;display:none;align-items:center;justify-content:center;background:rgba(0,0,0,.75);z-index:3000}
.lightbox.open{display:flex}
.lightbox-inner{position:relative;max-width:1100px;width:95%;max-height:90%;display:flex;align-items:center;gap:12px}
.lb-media{flex:1;display:flex;flex-direction:column;align-items:center}
.lb-media img{max-width:100%;max-height:80vh;border-radius:8px;box-shadow:0 12px 40px rgba(0,0,0,.5)}
.lb-caption{color:#fff;margin-top:12px;text-align:center}
.lb-counter{color:#dbe8dd;margin:2px 0 0;font-size:.9rem;font-weight:700}
.lb-close,.lb-nav{position:absolute;background:rgba(255,255,255,.06);border:0;color:#fff;padding:.6rem .8rem;border-radius:6px;cursor:pointer}
.lb-close{right:6px;top:6px}
.lb-prev{left:6px}
.lb-next{right:6px}
body.lightbox-active{overflow:hidden}


.video-grid{
  display:grid;
  grid-template-columns:
  repeat(auto-fit,minmax(340px,1fr));
  gap:30px;
}

.video-card{
  background:#fff;
  border-radius:16px;
  overflow:hidden;
  box-shadow:0 8px 24px rgba(0,0,0,.08);
}

.video-preview{
  width:100%;
  height:230px;
  border:none;
}
:global(.video-frame){display:block;width:100%;height:230px;border:0}
.video-preview{position:relative;display:block;padding:0;cursor:pointer;overflow:hidden;background:var(--verde)}
.video-preview img{width:100%;height:100%;object-fit:cover;opacity:.8;transition:.25s}
.video-preview:hover img{opacity:.62;transform:scale(1.03)}
.play-icon{position:absolute;top:50%;left:50%;display:grid;place-items:center;width:58px;height:58px;transform:translate(-50%,-50%);border-radius:50%;background:var(--naranja);color:#fff;padding-left:3px;box-shadow:0 6px 18px rgba(0,0,0,.25)}
.play-label{position:absolute;right:14px;bottom:12px;color:#fff;font-size:.8rem;font-weight:700;text-shadow:0 1px 3px #000}

.video-card h3{
  padding:18px;
  margin:0;
  color:var(--texto);
  font-size:1rem;
}

@media(max-width:768px){

  .multimedia-hero{
    padding:70px 0 35px;
  }

  .gallery-grid{
    grid-template-columns:1fr 1fr;
    gap:14px;
    grid-auto-rows:160px;
  }

  .gallery-card-featured-right{grid-column:span 2}
  .gallery-card-featured{grid-row:span 2}

  .video-grid{
    grid-template-columns:1fr;
  }

}

@media(max-width:480px){

  .gallery-grid{
    grid-template-columns:1fr;
    grid-auto-rows:230px;
  }

  .gallery-card-featured{grid-column:span 1;grid-row:span 1}
  .gallery-card-featured-right{grid-column:span 1}

}
</style>
